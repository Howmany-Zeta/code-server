{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "auth-docen: /docen @ startudiscovery.com (workspace = auth-docen)",
      "program": "${workspaceFolder}/out/node/entry.js",
      "cwd": "${workspaceFolder}",
      "env": {
        "VSCODE_IPC_HOOK_CLI": "",
        "CODE_SERVER_CONFIG": "${workspaceFolder}/config/startu.docen.path.yaml",
        "JWT_SECRET": "dev-placeholder-sync-with-express-gateway",
        "STARTU_GATEWAY_URL": "http://127.0.0.1:3001"
      },
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "auth-docen: /docen @ startudiscovery.com (workspace = monorepo root)",
      "program": "${workspaceFolder}/auth-docen/out/node/entry.js",
      "cwd": "${workspaceFolder}/auth-docen",
      "env": {
        "VSCODE_IPC_HOOK_CLI": "",
        "CODE_SERVER_CONFIG": "${workspaceFolder}/auth-docen/config/startu.docen.path.yaml",
        "JWT_SECRET": "dev-placeholder-sync-with-express-gateway",
        "STARTU_GATEWAY_URL": "http://127.0.0.1:3001"
      },
      "console": "integratedTerminal"
    }
  ]
}
